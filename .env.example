# SlackLite 환경 변수 (모두 선택 사항)
# 참고: 서버는 .env 파일을 자동으로 읽지 않습니다.
#   - 직접 실행:   PORT=8080 node server/index.js
#   - Docker:      docker compose 의 environment / env_file 사용

# 서버 포트 (기본 3000)
PORT=3000

# 바인딩 주소 (기본 0.0.0.0 — 모든 인터페이스)
HOST=0.0.0.0

# SQLite 데이터베이스 파일 경로 (기본 ./data.db)
DB_PATH=./data.db

# JWT 시크릿 파일 경로 (기본 ./.jwt-secret, 없으면 자동 생성)
SECRET_PATH=./.jwt-secret

# JWT 시크릿을 직접 지정 (지정 시 SECRET_PATH 무시)
# JWT_SECRET=change-me-to-a-long-random-string

# 회원가입을 초대 코드로 제한 (미설정 시 누구나 가입 가능)
# INVITE_CODE=our-team-invite

# 리버스 프록시(nginx/Caddy/Traefik) 뒤에서 운영 시 1로 설정
# TRUST_PROXY=1
